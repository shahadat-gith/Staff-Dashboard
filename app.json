{
  "expo": {
    "name": "Staff Dashboard",
    "slug": "staff dashboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "naa-teacher",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/favicon.png",
    "splash": {
      "image": "./assets/images/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.nashibaliacademy.teacher"
    },
    "android": {
      "package": "in.nashibaliacademy.teacher",
      "permissions": ["CAMERA"],
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundColor": "#E6F4FE"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "f9e9f8aa-cde5-4221-a3bd-c3a483c063ef"
      }
    },
    "owner": "shahadat.dev"
  }
}
